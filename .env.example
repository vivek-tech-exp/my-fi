# ── Environment ──────────────────────────────────────────────
MY_FI_ENVIRONMENT=local
MY_FI_API_HOST=127.0.0.1
MY_FI_API_PORT=8000

# ── Data paths ───────────────────────────────────────────────
# All runtime data defaults to ~/.my-fi/ on your machine.
# Your bank data never leaves your computer.
#
# Uncomment below to override (e.g. keep data inside the repo):
# MY_FI_DATA_DIR=./data
# MY_FI_STORAGE_DIR=./storage
# MY_FI_DATABASE_PATH=./storage/my_fi.duckdb
# MY_FI_LOGS_DIR=./storage/logs
# MY_FI_UPLOAD_STAGING_DIR=./storage/upload-staging

# ── Upload limits ────────────────────────────────────────────
# MY_FI_MAX_UPLOAD_FILE_SIZE_BYTES=262144000
